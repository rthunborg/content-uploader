{
  "name": "stena-content-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src worker next.config.ts vitest.config.ts drizzle.config.ts eslint.config.mjs eslint-boundaries.test.ts ci-workflows.test.ts",
    "worker": "tsx watch worker/index.ts",
    "test": "vitest run",
    "e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:push": "supabase db push",
    "create-admin": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.1",
    "@supabase/supabase-js": "2.110.3",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "postgres": "3.4.7",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/fontkit": "2.0.8",
    "@types/node": "22.19.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "fontkit": "2.0.4",
    "jsdom": "29.1.1",
    "shadcn": "4.13.0",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "$esbuild"
    },
    "next": {
      "postcss": "8.5.10"
    }
  }
}
